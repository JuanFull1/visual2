package practica1;

import java.sql.Connection;
import java.sql.ResultSet;
import java.sql.Statement;
import javax.swing.JOptionPane;
import javax.swing.JTextField;

public class TextFieldBDMio extends JTextField {
    
    public TextFieldBDMio() {
        super();
    }
    
    public void mostrarPrimerDato(String base, String tabla, String columna) {
        try {
            Conexion cn = new Conexion();
            Connection cc = cn.conectar(base);

            String sql = "SELECT " + columna + " FROM " + tabla + " LIMIT 1";
            Statement st = cc.createStatement();
            ResultSet rs = st.executeQuery(sql);

            if (rs.next()) {
                this.setText(rs.getString(columna));
            }

            rs.close();
            st.close();
            cc.close();

        } catch (Exception e) {
            JOptionPane.showMessageDialog(null, "Error al mostrar dato: " + e.getMessage());
        }
    }
}


