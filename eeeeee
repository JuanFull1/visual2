package practica1;

import java.sql.Connection;
import java.sql.ResultSet;
import java.sql.Statement;
import javax.swing.JOptionPane;
import javax.swing.JTextArea;

public class TextAreaBDMio extends JTextArea {
    
    public TextAreaBDMio() {
        super();
    }
    
    public void mostrarColumnaTexto(String base, String tabla, String columna) {
        try {
            this.setText("");

            Conexion cn = new Conexion();
            Connection cc = cn.conectar(base);

            String sql = "SELECT " + columna + " FROM " + tabla;
            Statement st = cc.createStatement();
            ResultSet rs = st.executeQuery(sql);

            while (rs.next()) {
                this.append(rs.getString(columna) + "\n");
            }

            rs.close();
            st.close();
            cc.close();

        } catch (Exception e) {
            JOptionPane.showMessageDialog(null, "Error al mostrar datos: " + e.getMessage());
        }
    }
}



